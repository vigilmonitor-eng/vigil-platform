# ─────────────────────────────────────────────────────────────
# VIGIL Platform — Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────────────────────

# AlienVault OTX — Free, get key at: https://otx.alienvault.com/api
# Provides 10,000 req/hour at no cost, no commercial restriction
OTX_API_KEY=your_otx_api_key_here

# Open-Meteo — No key needed, already free & commercial OK
# (used for weather/storm overlays)
# OPEN_METEO_BASE=https://api.open-meteo.com/v1

# NASA FIRMS — Free fire data, register at: https://firms.modaps.eosdis.nasa.gov/api/
# Optional - adds wildfire hotspot markers on map
NASA_FIRMS_KEY=your_nasa_firms_key_here

# ─────────────────────────────────────────────────────────────
# The following sources need NO key and are used automatically:
# • GDELT Project (news)         — no auth needed
# • Yahoo Finance (markets)      — no auth needed
# • CoinGecko (crypto)           — no auth needed
# • USGS Earthquakes             — no auth needed
# • GDACS / UN (disasters)       — no auth needed
# • CISA Advisories RSS          — no auth needed
# • CVE CircL                    — no auth needed
# ─────────────────────────────────────────────────────────────

# App config
NEXT_PUBLIC_APP_NAME=VIGIL
NEXT_PUBLIC_REFRESH_INTERVAL=120000
